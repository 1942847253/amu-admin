VITE_DEV_PORT=5174
VITE_API_PROXY_TARGET=http://localhost:3000
# 生产环境可配置独立后端地址，例如 https://api.example.com 或 http://1.2.3.4:3000
VITE_API_BASE_URL=
# 留空时自动探测当前是否处于 monorepo workspace 中
VITE_USE_WORKSPACE_SOURCE=
# 前端访问基路径，根路径部署填 /，子路径部署可填 /amu-admin/
VITE_APP_BASE_PATH=/
VITE_APP_NAME=Amu Admin
VITE_APP_SHORT_NAME=AM
VITE_APP_TITLE=企业级后台管理系统模板
VITE_APP_DESCRIPTION=面向大型业务系统的前端基础底座，内置权限、路由、主题、标签页与请求链路最佳实践。
VITE_APP_COPYRIGHT=Copyright © 2026 Amu UI Team.
